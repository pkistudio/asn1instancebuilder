{
  "name": "@pkistudio/asn1instancebuilder",
  "version": "0.1.1",
  "description": "Browser-first ASN.1 instance builder for creating DER data from schema models.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/types/core.d.ts",
      "import": "./dist/core.js"
    },
    "./app": {
      "types": "./dist/types/app.d.ts",
      "import": "./dist/app.js"
    },
    "./styles.css": "./dist/asn1instancebuilder.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite --config vite.app.config.ts",
    "build": "npm run build:types && npm run build:lib && npm run build:app",
    "build:app": "vite build --config vite.app.config.ts --outDir dist/app-shell",
    "build:lib": "vite build",
    "build:types": "tsc -p tsconfig.types.json",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "pack:dry-run": "npm pack --dry-run"
  },
  "dependencies": {
    "@pkistudio/pkistudiojs": "^0.6.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pkistudio/asn1instancebuilder"
  },
  "keywords": [
    "asn1",
    "der",
    "pki",
    "x509",
    "pkistudio"
  ],
  "bugs": {
    "url": "https://github.com/pkistudio/asn1instancebuilder/issues"
  },
  "homepage": "https://github.com/pkistudio/asn1instancebuilder#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  }
}
