{
  "name": "@pkistudio/asn1instancebuilder",
  "version": "0.0.0",
  "description": "Browser-first ASN.1 instance builder for creating DER data from schema models.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "default": "./dist/app.js"
    },
    "./styles.css": "./dist/asn1instancebuilder.css"
  },
  "scripts": {
    "dev": "vite --config vite.app.config.ts",
    "build": "npm run build:types && npm run build:lib && npm run build:app",
    "build:app": "vite build --config vite.app.config.ts --outDir dist/app-shell",
    "build:lib": "vite build",
    "build:types": "tsc -p tsconfig.types.json",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "pack:dry-run": "npm pack --dry-run"
  },
  "dependencies": {
    "@pkistudio/pkistudiojs": "^0.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  }
}
